---
import Layout from '../layouts/Layout.astro';
import BackgroundGlow from '../components/BackgroundGlow.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import Philosophy from '../components/Philosophy.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const title = 'Henry Carmenate — Senior Full-Stack Engineer';
const description = 'Henry Carmenate — Senior Full-Stack Engineer (Laravel, Vue, AWS). Fintech & SaaS. Portfolio.';
---

<Layout title={title} description={description}>
  <BackgroundGlow />
  <Header />
  <main id="top" class="relative">
    <Hero />
    <Projects />
    <Philosophy />
    <Experience />
    <Skills />
    <Contact />
  </main>
  <Footer />
</Layout>
