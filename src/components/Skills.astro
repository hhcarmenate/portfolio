---
// Skills section
---

<section id="skills" class="mx-auto max-w-7xl px-6 section-spacing reveal">
  <h2 class="h2-divider text-3xl tracking-tight">Skills</h2>
  <div class="mt-6 grid gap-4 md:grid-cols-2">
    <article class="reveal rounded-3xl card-premium p-8 border-l-4 border-blue-500/40">
      <h3 class="flex items-center gap-2 text-base font-semibold text-blue-300">
        <span class="text-lg">⚙️</span>
        Backend
      </h3>
      <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-300">
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">PHP 8.x</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Laravel 11/12</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">REST APIs</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Sanctum</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Queues</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">MySQL</span>
      </div>
    </article>
    <article class="reveal rounded-3xl card-premium p-8 border-l-4 border-cyan-500/40">
      <h3 class="flex items-center gap-2 text-base font-semibold text-cyan-300">
        <span class="text-lg">💎</span>
        Frontend
      </h3>
      <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-300">
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Vue 3</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Vite</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Pinia</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Tailwind CSS</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Vitest</span>
      </div>
    </article>
    <article class="reveal rounded-3xl card-premium p-8 border-l-4 border-orange-500/40">
      <h3 class="flex items-center gap-2 text-base font-semibold text-orange-300">
        <span class="text-lg">☁️</span>
        Cloud & DevOps
      </h3>
      <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-300">
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">AWS S3</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">AWS SES</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">AWS SQS</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Docker</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">CI/CD</span>
      </div>
    </article>
    <article class="reveal rounded-3xl card-premium p-8 border-l-4 border-green-500/40">
      <h3 class="flex items-center gap-2 text-base font-semibold text-green-300">
        <span class="text-lg">📐</span>
        Practices
      </h3>
      <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-300">
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Testing</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Scrum</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Performance</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Code Review</span>
      </div>
    </article>
    <article class="reveal rounded-3xl card-premium p-8 border-l-4 border-violet-500/40 md:col-span-2">
      <h3 class="flex items-center gap-2 text-base font-semibold text-violet-300">
        <span class="text-lg">🏛️</span>
        Architecture
      </h3>
      <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-300">
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">DDD</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Event-Driven</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Modular Systems</span>
        <span class="rounded-full bg-white/5 px-3 py-1 ring-1 ring-white/10">Microservices</span>
      </div>
    </article>
  </div>
</section>
