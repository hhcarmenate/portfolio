---
import LucideIcon from './LucideIcon.astro';
import { Layers, LayoutTemplate, Database, Workflow } from 'lucide';

const groups = [
  {
    title: 'Backend & Architecture',
    summary:
      'Designing scalable backend systems with clean architecture, modular design, and long-term maintainability.',
    icon: Layers,
    accent: 'text-blue-300',
    iconBg: 'from-blue-500/25 to-blue-600/10 border-blue-400/25',
    tags: [
      'Laravel · PHP',
      'API Design (REST)',
      'Modular Systems',
      'Event-driven design',
      'DDD principles',
      'Microservices',
    ],
  },
  {
    title: 'Frontend Systems',
    summary:
      'Building modern, high-performance interfaces with strong component architecture and maintainable UI systems.',
    icon: LayoutTemplate,
    accent: 'text-teal-300',
    iconBg: 'from-teal-500/22 to-teal-600/10 border-teal-400/22',
    tags: [
      'Vue 3 · Vite · Pinia',
      'Tailwind CSS',
      'Component Architecture',
      'Responsive UI',
      'Frontend Performance',
      'Testing (Vitest)',
    ],
  },
  {
    title: 'Data & Infrastructure',
    summary:
      'Managing data layers, integrations, and cloud services to support reliable, production-grade systems.',
    icon: Database,
    accent: 'text-sky-300',
    iconBg: 'from-sky-500/20 to-sky-600/10 border-sky-400/25',
    tags: [
      'MySQL · PostgreSQL',
      'AWS (S3 · SES · SQS)',
      'Docker',
      'Queues & background jobs',
      'CI/CD',
      'System integrations',
    ],
  },
  {
    title: 'Engineering & AI Workflows',
    summary:
      'Applying structured engineering practices and AI-assisted workflows to improve speed, quality, and system reliability.',
    icon: Workflow,
    accent: 'text-violet-300',
    iconBg: 'from-violet-500/22 to-violet-600/10 border-violet-400/25',
    tags: [
      'Clean Architecture',
      'Testing & Debugging',
      'Performance Optimization',
      'Code Reviews',
      'AI-assisted development',
      'Spec-driven workflows',
    ],
  },
];
---

<section id="skills" class="skills-section mx-auto max-w-7xl px-6 section-spacing reveal">
  <header class="skills-header max-w-2xl">
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-teal-400/85 md:text-xs">Skills</p>
    <h2 class="h2-divider mt-3 text-3xl font-bold tracking-tight text-white md:text-4xl">
      A clear capability map
    </h2>
    <p class="mt-3 text-base leading-relaxed text-slate-400">
      Structured strengths across the stack — how systems are designed, built, shipped, and kept reliable.
    </p>
  </header>

  <div class="mt-10 grid auto-rows-fr gap-7 md:grid-cols-2 md:gap-8">
    {
      groups.map((g, i) => (
        <article
          class="skill-card reveal glass flex h-full flex-col rounded-3xl p-7 md:p-8"
          style={`--reveal-delay: ${i * 40}ms`}
          aria-labelledby={`skill-${i}-title`}
        >
          <div
            class:list={[
              'skill-icon-ring inline-flex w-fit rounded-2xl border bg-gradient-to-br p-3 ring-1 ring-white/[0.06]',
              g.iconBg,
            ]}
          >
            <LucideIcon icon={g.icon} size={26} class={g.accent} />
          </div>
          <h3 id={`skill-${i}-title`} class="mt-5 text-xl font-bold tracking-tight text-white md:text-2xl">
            {g.title}
          </h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400 md:text-[15px]">{g.summary}</p>
          <ul
            class="project-tags mt-6 flex flex-wrap gap-x-2 gap-y-2.5 md:mt-7"
            aria-label={`${g.title} — capability areas`}
          >
            {g.tags.map((t) => (
              <li class="project-tag">{t}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>

<style>
  .skill-card {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 22px 52px -38px rgba(0, 0, 0, 0.72);
    transition:
      transform 0.28s ease,
      border-color 0.28s ease,
      box-shadow 0.28s ease;
  }

  .skill-card::before {
    content: '';
    position: absolute;
    left: 1.15rem;
    right: 1.15rem;
    top: 0;
    height: 1px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, rgba(45, 212, 191, 0.22), rgba(15, 118, 110, 0.26), transparent);
    opacity: 0.85;
    pointer-events: none;
  }

  .skill-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.11);
    box-shadow:
      0 28px 58px -38px rgba(0, 0, 0, 0.78),
      0 0 0 1px rgba(45, 212, 191, 0.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-card:hover {
      transform: none;
    }
  }
</style>
