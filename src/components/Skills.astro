---
import LucideIcon from './LucideIcon.astro';
import {
  Server,
  LayoutTemplate,
  Cloud,
  ClipboardCheck,
  Layers,
  BrainCircuit,
} from 'lucide';

const groups = [
  {
    title: 'Backend',
    summary: 'APIs, queues, and data layers engineered for clarity and scale.',
    icon: Server,
    accent: 'text-blue-300',
    iconBg: 'from-blue-500/25 to-blue-600/10 border-blue-400/25',
    tags: ['PHP 8.x', 'Laravel 11/12', 'REST APIs', 'Sanctum', 'Queues', 'MySQL'],
  },
  {
    title: 'Frontend',
    summary: 'Composable UIs, fast builds, and interfaces that stay maintainable.',
    icon: LayoutTemplate,
    accent: 'text-cyan-300',
    iconBg: 'from-cyan-500/25 to-cyan-600/10 border-cyan-400/25',
    tags: ['Vue 3', 'Vite', 'Pinia', 'Tailwind CSS', 'Vitest'],
  },
  {
    title: 'Cloud & DevOps',
    summary: 'Delivery pipelines and cloud primitives that survive production traffic.',
    icon: Cloud,
    accent: 'text-sky-300',
    iconBg: 'from-sky-500/20 to-sky-600/10 border-sky-400/25',
    tags: ['AWS S3', 'AWS SES', 'AWS SQS', 'Docker', 'CI/CD'],
  },
  {
    title: 'Practices',
    summary: 'How work gets done — repeatable quality, not ad-hoc heroics.',
    icon: ClipboardCheck,
    accent: 'text-emerald-300',
    iconBg: 'from-emerald-500/20 to-emerald-600/10 border-emerald-400/25',
    tags: ['Testing', 'Scrum', 'Performance', 'Code review'],
  },
  {
    title: 'Architecture',
    summary: 'Boundaries, events, and modular design that reduce long-term risk.',
    icon: Layers,
    accent: 'text-violet-300',
    iconBg: 'from-violet-500/22 to-violet-600/10 border-violet-400/25',
    tags: ['DDD', 'Event-driven', 'Modular systems', 'Microservices'],
  },
  {
    title: 'AI-augmented engineering',
    summary:
      'Spec-driven and agent-assisted delivery—faster iteration with reviews, context discipline, and human ownership of quality.',
    icon: BrainCircuit,
    accent: 'text-cyan-200',
    iconBg: 'from-cyan-500/25 to-blue-600/10 border-cyan-400/25',
    tags: [
      'AI-assisted implementation',
      'Agentic workflows',
      'Spec-driven development',
      'Prompt & context design',
      'Human-in-the-loop review',
    ],
  },
];
---

<section id="skills" class="skills-section mx-auto max-w-7xl px-6 section-spacing reveal">
  <header class="skills-header max-w-2xl">
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-400/85 md:text-xs">Skills</p>
    <h2 class="h2-divider mt-3 text-3xl font-bold tracking-tight text-white md:text-4xl">
      Depth across the stack — plus modern delivery
    </h2>
    <p class="mt-3 text-base leading-relaxed text-slate-400">
      Capabilities grouped the way hiring teams scan them: concrete tech, proven practices, and pragmatic AI-augmented
      workflows.
    </p>
  </header>

  <div class="mt-10 grid auto-rows-fr gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-7">
    {
      groups.map((g, i) => (
        <article
          class="skill-card reveal glass flex h-full flex-col rounded-3xl p-7 md:p-8"
          style={`--reveal-delay: ${i * 40}ms`}
          aria-labelledby={`skill-${i}-title`}
        >
          <div
            class:list={[
              'skill-icon-ring inline-flex w-fit rounded-2xl border bg-gradient-to-br p-3 ring-1 ring-white/[0.06]',
              g.iconBg,
            ]}
          >
            <LucideIcon icon={g.icon} size={26} class={g.accent} />
          </div>
          <h3 id={`skill-${i}-title`} class="mt-5 text-lg font-bold tracking-tight text-white md:text-xl">
            {g.title}
          </h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400 md:text-[15px]">{g.summary}</p>
          <p class="skill-tags-label mt-6">Focus</p>
          <ul class="project-tags mt-3 flex flex-wrap gap-2" aria-label={`${g.title} — focus areas`}>
            {g.tags.map((t) => (
              <li class="project-tag">{t}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>

<style>
  .skill-card {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 22px 52px -38px rgba(0, 0, 0, 0.72);
    transition:
      transform 0.28s ease,
      border-color 0.28s ease,
      box-shadow 0.28s ease;
  }

  .skill-card::before {
    content: '';
    position: absolute;
    left: 1.15rem;
    right: 1.15rem;
    top: 0;
    height: 1px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, rgba(34, 211, 238, 0.28), rgba(37, 99, 235, 0.32), transparent);
    opacity: 0.85;
    pointer-events: none;
  }

  .skill-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.11);
    box-shadow:
      0 28px 58px -38px rgba(0, 0, 0, 0.78),
      0 0 0 1px rgba(34, 211, 238, 0.05);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-card:hover {
      transform: none;
    }
  }

  .skill-tags-label {
    margin: 0;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.95);
  }
</style>
