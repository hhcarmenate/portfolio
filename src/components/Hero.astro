---
// Hero — premium product-engineering narrative + supporting bento
---

<section class="hero-section relative flex min-h-screen flex-col" id="top" role="banner" aria-label="Hero — Senior Full-Stack Engineer">
  <!-- Top meta: availability + positioning tag (single scan line) -->
  <div class="hero-shell mx-auto w-full max-w-6xl px-6 pt-8">
    <div class="hero-meta reveal flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between" style="--reveal-delay: 0ms">
      <div
        class="inline-flex w-fit items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-2 text-xs backdrop-blur-sm"
        role="status"
        aria-label="Available for remote opportunities; based in Miami, Florida"
      >
        <span class="relative flex h-2 w-2 shrink-0" aria-hidden="true">
          <span class="ping-dot absolute inline-flex h-full w-full rounded-full opacity-75" style="background: var(--c-secondary)"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full" style="background: var(--c-secondary)"></span>
        </span>
        <span class="text-slate-300">Open to remote · Miami, FL</span>
      </div>
      <p class="text-[10px] font-medium uppercase tracking-[0.22em] text-slate-500">
        Fintech · SaaS · Platforms
      </p>
    </div>
  </div>

  <!-- Main narrative -->
  <div class="hero-shell mx-auto flex w-full max-w-6xl flex-1 flex-col px-6 pb-8 pt-6 md:pt-10">
    <div class="hero-narrative mx-auto w-full max-w-3xl text-center">
      <p
        class="reveal mb-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-400/90 md:text-xs"
        style="--reveal-delay: 50ms"
      >
        Senior Full-Stack · Laravel · Vue · PHP · AWS
      </p>

      <h1
        class="hero-headline reveal font-bold tracking-tight text-white"
        style="--reveal-delay: 100ms; font-size: clamp(2.75rem, 7.5vw, 5.75rem);"
        aria-label="Senior Full-Stack Engineer specializing in fintech and SaaS"
      >
        Senior <span class="hero-gradient-text">Full‑Stack</span><br />
        Engineer
      </h1>

      <p class="reveal hero-tagline mt-5 text-sm font-medium text-slate-300 md:text-base" style="--reveal-delay: 150ms">
        Scalable web products — APIs, services, and product-grade interfaces for teams that ship.
      </p>

      <p
        class="reveal mx-auto mt-4 max-w-2xl text-[15px] leading-relaxed text-slate-400 md:text-base"
        style="--reveal-delay: 180ms"
      >
        15+ years delivering production fintech and SaaS: high-volume APIs, thoughtful architecture, and UX that
        holds up under real load — MySQL, PostgreSQL, and AWS included.
      </p>

      <ul
        class="reveal mx-auto mt-7 flex max-w-xl flex-wrap justify-center gap-2 md:gap-2.5"
        style="--reveal-delay: 220ms"
        aria-label="Focus areas"
      >
        <li class="hero-chip">SaaS &amp; platform work</li>
        <li class="hero-chip">Production APIs</li>
        <li class="hero-chip">Laravel &amp; Vue</li>
        <li class="hero-chip">Product-minded delivery</li>
      </ul>

      <div class="reveal mt-9 flex flex-col items-center gap-4 sm:flex-row sm:justify-center sm:gap-3" style="--reveal-delay: 280ms">
        <a
          class="hero-cta-primary glow-pulse inline-flex min-h-[44px] w-full items-center justify-center rounded-2xl px-8 py-3.5 text-sm font-semibold text-white shadow-lg transition-transform duration-300 hover:-translate-y-0.5 sm:w-auto"
          href="#contact"
          aria-label="Go to contact section"
        >
          Get in touch
        </a>
        <a
          class="hero-cta-secondary inline-flex min-h-[44px] w-full items-center justify-center rounded-2xl border border-white/15 bg-white/[0.04] px-8 py-3.5 text-sm font-semibold text-slate-100 backdrop-blur-sm transition-all duration-300 hover:border-white/25 hover:bg-white/[0.08] sm:w-auto"
          href="#projects"
          aria-label="View selected projects"
        >
          View selected work
        </a>
      </div>

      <p class="reveal mt-4 text-sm text-slate-500" style="--reveal-delay: 320ms">
        <a
          class="underline decoration-white/20 underline-offset-4 transition-colors hover:text-cyan-300/90 hover:decoration-cyan-400/40"
          href="mailto:henrycarmenateg@gmail.com"
        >
          henrycarmenateg@gmail.com
        </a>
      </p>

      <div
        class="reveal hero-metrics mt-10 border-y border-white/[0.07] py-8 md:mt-12"
        style="--reveal-delay: 360ms"
        role="group"
        aria-label="Career impact metrics"
      >
        <div class="flex flex-wrap items-start justify-center gap-x-10 gap-y-6 sm:gap-x-14">
          <div class="hero-metric text-center sm:text-left">
            <p class="hero-metric-value" aria-label="More than fifteen years experience">15+</p>
            <p class="hero-metric-label">Years in production engineering</p>
          </div>
          <div class="hidden h-10 w-px bg-white/10 sm:block" aria-hidden="true"></div>
          <div class="hero-metric text-center sm:text-left">
            <p class="hero-metric-value" aria-label="More than forty modules migrated">40+</p>
            <p class="hero-metric-label">Features &amp; modules shipped</p>
          </div>
          <div class="hidden h-10 w-px bg-white/10 sm:block" aria-hidden="true"></div>
          <div class="hero-metric text-center sm:text-left">
            <p class="hero-metric-value" aria-label="Thirty five percent load time reduction">35%</p>
            <p class="hero-metric-label">Measured performance win</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Supporting bento -->
    <div class="reveal mx-auto mt-10 grid w-full max-w-5xl gap-4 md:mt-12 lg:grid-cols-3" style="--reveal-delay: 420ms">
      <div class="hero-card glass rounded-3xl p-6 text-left md:p-7" role="region" aria-label="Career highlights">
        <h2 class="hero-card-title h2-divider text-[10px] font-semibold uppercase tracking-[0.16em] text-slate-400">Highlights</h2>
        <ul class="mt-5 space-y-4 text-sm leading-snug text-slate-300" role="list">
          <li class="flex gap-3" role="listitem">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--c-primary)" aria-hidden="true"></span>
            Led modernization of high-volume fintech portals and API platforms.
          </li>
          <li class="flex gap-3" role="listitem">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--c-secondary)" aria-hidden="true"></span>
            Built scalable modules: RSVP, guests, menus, locations, permissions, activity logs.
          </li>
          <li class="flex gap-3" role="listitem">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: rgba(34,211,238,0.85)" aria-hidden="true"></span>
            Product mindset: UX polish, performance, observability, maintainability.
          </li>
        </ul>
      </div>

      <div class="hero-card glass rounded-3xl p-6 text-left md:p-7" role="region" aria-label="Technology stack and employers">
        <h2 class="hero-card-title h2-divider text-[10px] font-semibold uppercase tracking-[0.16em] text-slate-400">Core stack</h2>
        <div class="mt-5 flex flex-wrap gap-2" role="list">
          <span class="hero-stack-pill" role="listitem">Laravel 11/12</span>
          <span class="hero-stack-pill" role="listitem">PHP</span>
          <span class="hero-stack-pill" role="listitem">Vue 3 · Vite</span>
          <span class="hero-stack-pill" role="listitem">Pinia</span>
          <span class="hero-stack-pill" role="listitem">REST APIs</span>
          <span class="hero-stack-pill" role="listitem">MySQL · PostgreSQL</span>
          <span class="hero-stack-pill" role="listitem">AWS</span>
          <span class="hero-stack-pill" role="listitem">Docker / CI/CD</span>
        </div>

        <div class="mt-7 border-t border-white/[0.06] pt-6">
          <p class="hero-card-title mb-4 text-[10px] font-semibold uppercase tracking-[0.16em] text-slate-400">Trusted experience</p>
          <div class="flex flex-wrap items-center gap-3 md:gap-4" role="list">
            <a
              class="logo-badge"
              role="listitem"
              href="https://www.linkedin.com/company/the-bank-of-orrick/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TBO Bank on LinkedIn (opens in new tab)"
            >
              <img src="/logos/the_bank_of_orrick_logo.jfif" alt="" class="h-11 w-auto object-contain md:h-12" />
              <span class="logo-tooltip">TBO Bank</span>
            </a>
            <a
              class="logo-badge"
              role="listitem"
              href="https://www.linkedin.com/company/hyphenfi/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Hyphen Finance on LinkedIn (opens in new tab)"
            >
              <img src="/logos/hyphenfi_logo.jfif" alt="" class="h-11 w-auto object-contain md:h-12" />
              <span class="logo-tooltip">Hyphen Finance</span>
            </a>
            <a
              class="logo-badge"
              role="listitem"
              href="https://www.linkedin.com/company/openlane/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="OPENLANE on LinkedIn (opens in new tab)"
            >
              <img src="/logos/kar_auction_services_inc_logo.jfif" alt="" class="h-11 w-auto object-contain md:h-12" />
              <span class="logo-tooltip">OPENLANE</span>
            </a>
          </div>
        </div>
      </div>

      <div class="hero-card glass rounded-3xl p-6 text-left md:p-7" role="region" aria-label="Contact">
        <h2 class="hero-card-title h2-divider text-[10px] font-semibold uppercase tracking-[0.16em] text-slate-400">Contact</h2>
        <nav class="mt-5 grid gap-2 text-sm" aria-label="Contact links">
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="mailto:henrycarmenateg@gmail.com"
            aria-label="Send email to Henry Carmenate"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            henrycarmenateg@gmail.com
          </a>
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="tel:+1-786-316-5465"
            aria-label="Call +1 (786) 316-5465"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (786) 316-5465
          </a>
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="https://www.linkedin.com/in/henry-carmenate/"
            rel="noopener noreferrer"
            target="_blank"
            aria-label="Visit LinkedIn profile"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="https://github.com/hhcarmenate"
            rel="noopener noreferrer"
            target="_blank"
            aria-label="Visit GitHub profile"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.929.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </nav>
      </div>
    </div>
  </div>

  <div class="hero-scroll-ledge border-t border-white/[0.06]">
    <div class="hero-shell mx-auto flex max-w-6xl items-center justify-end px-6 py-4 md:py-5">
      <div class="scroll-hint flex flex-col items-center gap-1.5 opacity-45 outline-none" aria-hidden="true">
        <p class="text-[10px] font-medium uppercase tracking-[0.2em] text-slate-400">Scroll</p>
        <svg class="h-4 w-4 text-cyan-400/90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-headline {
    line-height: 1.12;
    overflow: visible;
    padding-bottom: 0.08em;
    color: #ffffff;
  }

  .hero-gradient-text {
    background: linear-gradient(120deg, #fff 20%, var(--c-secondary) 58%, var(--c-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(255, 255, 255, 0.04);
    padding: 0.4rem 0.85rem;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #cbd5e1;
    list-style: none;
  }

  .hero-cta-primary {
    background: linear-gradient(135deg, var(--c-primary), var(--c-secondary));
  }

  .hero-metrics .hero-metric-value {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--c-primary);
    line-height: 1.1;
  }

  .hero-metrics .hero-metric-label {
    margin-top: 0.35rem;
    max-width: 9rem;
    margin-left: auto;
    margin-right: auto;
    font-size: 11px;
    line-height: 1.35;
    color: #94a3b8;
  }

  @media (min-width: 640px) {
    .hero-metrics .hero-metric-label {
      margin-left: 0;
      margin-right: 0;
      max-width: 10.5rem;
    }
  }

  .hero-card {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 24px 48px -32px rgba(0, 0, 0, 0.65);
  }

  .hero-card::before {
    content: '';
    position: absolute;
    left: 1rem;
    right: 1rem;
    top: 0;
    height: 1px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, rgba(34, 211, 238, 0.35), rgba(37, 99, 235, 0.45), transparent);
    opacity: 0.85;
    pointer-events: none;
  }

  .hero-card-title.h2-divider::after {
    width: 56px;
    margin-top: 8px;
  }

  .hero-stack-pill {
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.3rem 0.7rem;
    font-size: 11px;
    color: #cbd5e1;
    letter-spacing: 0.01em;
  }

  .ping-dot {
    animation: ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping {
    75%, 100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  .glow-pulse {
    animation: glowPulse 2.4s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { box-shadow: 0 0 16px rgba(34, 211, 238, 0.28); }
    50%       { box-shadow: 0 0 32px rgba(34, 211, 238, 0.45); }
  }

  .scroll-hint {
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  .reveal {
    animation: revealFade 700ms ease forwards;
    opacity: 0;
    transform: translateY(18px);
    filter: blur(5px);
  }

  .reveal.reveal--visible {
    animation: revealShow 700ms ease forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  @keyframes revealFade {
    to {
      opacity: 0;
      transform: translateY(18px);
      filter: blur(5px);
    }
  }

  @keyframes revealShow {
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glow-pulse,
    .ping-dot,
    .scroll-hint,
    .h2-divider {
      animation: none;
    }
    .reveal {
      opacity: 1;
      transform: none;
      filter: none;
      animation: none;
    }
  }

  .logo-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    filter: grayscale(1);
    opacity: 0.82;
    transition: filter 0.3s ease, opacity 0.3s ease, background 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .logo-badge:focus-visible {
    outline: 2px solid var(--c-primary);
    outline-offset: 3px;
  }

  .logo-badge:hover {
    filter: grayscale(0);
    opacity: 1;
    background: rgba(255, 255, 255, 0.09);
  }

  .logo-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    white-space: nowrap;
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #cbd5e1;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 4px 10px;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    backdrop-filter: blur(8px);
    z-index: 10;
  }

  .logo-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: rgba(255, 255, 255, 0.1);
  }

  .logo-badge:hover .logo-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media print {
    .scroll-hint,
    .ping-dot {
      display: none;
    }
  }
</style>
