---
// Hero section — editorial centered layout with bento card grid
---

<section class="relative flex min-h-screen flex-col" id="top" role="banner" aria-label="Hero section - Senior Full-Stack Engineer">

  <!-- ── Top strip: availability + label ── -->
  <div class="mx-auto w-full max-w-6xl px-6 pt-8 flex items-center justify-between">
    <div
      class="reveal inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/5 px-3.5 py-1.5 text-xs backdrop-blur-sm"
      style="--reveal-delay: 0ms"
      role="status"
      aria-label="Currently available for remote work in Miami, Florida"
    >
      <span class="relative flex h-2 w-2 shrink-0" aria-hidden="true">
        <span class="ping-dot absolute inline-flex h-full w-full rounded-full opacity-75" style="background: var(--c-secondary)"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full" style="background: var(--c-secondary)"></span>
      </span>
      <span class="text-slate-300">Available for remote work · Miami, FL</span>
    </div>
    <span class="reveal text-[10px] uppercase tracking-widest text-slate-500" style="--reveal-delay: 0ms" aria-hidden="true">
      2026 · Fintech &amp; SaaS
    </span>
  </div>

  <!-- ── Center stage ── -->
  <div class="flex flex-1 flex-col items-center justify-center px-6 pb-6 pt-12 text-center">

    <!-- Eyebrow -->
    <p
      class="reveal mb-7 flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300/80"
      style="--reveal-delay: 60ms"
      aria-hidden="true"
    >
      <span class="h-px w-10 bg-cyan-400/30"></span>
      Laravel · Vue · AWS
      <span class="h-px w-10 bg-cyan-400/30"></span>
    </p>

    <!-- Headline -->
    <h1
      class="hero-headline reveal max-w-4xl font-bold tracking-tight"
      style="--reveal-delay: 120ms; font-size: clamp(3.4rem, 8vw, 6.75rem);"
      aria-label="Senior Full-Stack Engineer specialized in fintech and SaaS"
    >
      Senior <span class="hero-gradient-text">Full‑Stack</span><br />
      Engineer
    </h1>

    <!-- Bio -->
    <p
      class="reveal mt-8 max-w-lg text-base leading-relaxed text-slate-400"
      style="--reveal-delay: 220ms"
    >
      15+ years building fintech and SaaS platforms — high-volume APIs,
      scalable modules, and product-grade UX across the full stack.
    </p>

    <!-- CTAs -->
    <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-3" style="--reveal-delay: 300ms">
      <a
        class="glow-pulse inline-flex items-center justify-center rounded-2xl px-7 py-3.5 text-sm font-semibold text-white shadow-lg transition-all duration-300"
        href="#contact"
        aria-label="Contact me"
        style="background: linear-gradient(135deg, var(--c-primary), var(--c-secondary))"
      >
        Contact me
      </a>
      <a
        class="inline-flex items-center justify-center rounded-2xl bg-white/5 px-7 py-3.5 text-sm font-semibold transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
        href="#projects"
        aria-label="View projects"
      >
        View projects
      </a>
      <a
        class="inline-flex items-center justify-center rounded-2xl bg-transparent px-7 py-3.5 text-sm font-semibold text-slate-300 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/5"
        href="mailto:henrycarmenateg@gmail.com"
        aria-label="Send email"
      >
        Email
      </a>
    </div>

    <!-- ── Bento grid of glass cards ── -->
    <div
      class="reveal mt-12 grid w-full max-w-5xl gap-4 lg:grid-cols-3"
      style="--reveal-delay: 390ms"
    >

      <!-- Card 1: Highlights -->
      <div class="glass rounded-3xl p-6 text-left" role="region" aria-label="Career highlights">
        <h2 class="h2-divider mb-4 text-[10px] font-semibold uppercase tracking-widest text-slate-400">Highlights</h2>
        <ul class="space-y-3.5 text-sm text-slate-300" role="list">
          <li class="flex gap-3 leading-snug" role="listitem">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--c-primary)" aria-hidden="true"></span>
            Led modernization of high-volume fintech portals and API platforms.
          </li>
          <li class="flex gap-3 leading-snug" role="listitem">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--c-secondary)" aria-hidden="true"></span>
            Built scalable modules: RSVP, guests, menus, locations, permissions, activity logs.
          </li>
          <li class="flex gap-3 leading-snug" role="listitem">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: rgba(34,211,238,0.85)" aria-hidden="true"></span>
            Strong product mindset: UX polish, performance, observability, and maintainability.
          </li>
        </ul>
      </div>

      <!-- Card 2: Tech + Logos -->
      <div class="glass rounded-3xl p-6 text-left" role="region" aria-label="Tech stack and trusted companies">
        <h2 class="h2-divider mb-4 text-[10px] font-semibold uppercase tracking-widest text-slate-400">Tech Stack</h2>
        <div class="flex flex-wrap gap-2" role="list">
          <span class="rounded-full bg-white/[0.06] px-3 py-1 text-[11px] text-slate-300 ring-1 ring-white/[0.08]" role="listitem">Laravel 11/12</span>
          <span class="rounded-full bg-white/[0.06] px-3 py-1 text-[11px] text-slate-300 ring-1 ring-white/[0.08]" role="listitem">Vue 3 + Vite</span>
          <span class="rounded-full bg-white/[0.06] px-3 py-1 text-[11px] text-slate-300 ring-1 ring-white/[0.08]" role="listitem">Pinia</span>
          <span class="rounded-full bg-white/[0.06] px-3 py-1 text-[11px] text-slate-300 ring-1 ring-white/[0.08]" role="listitem">REST APIs</span>
          <span class="rounded-full bg-white/[0.06] px-3 py-1 text-[11px] text-slate-300 ring-1 ring-white/[0.08]" role="listitem">AWS S3/SES/SQS</span>
          <span class="rounded-full bg-white/[0.06] px-3 py-1 text-[11px] text-slate-300 ring-1 ring-white/[0.08]" role="listitem">Docker / CI/CD</span>
        </div>

        <div class="mt-6 border-t border-white/[0.06] pt-5">
          <p class="mb-4 text-[10px] uppercase tracking-widest text-slate-400">Trusted experience with</p>
          <div class="flex flex-wrap items-center gap-4" role="list">

            <div class="logo-badge" role="listitem" aria-label="The Bank of Orrick">
              <img src="/logos/the_bank_of_orrick_logo.jfif" alt="The Bank of Orrick" class="h-12 w-auto object-contain" />
              <span class="logo-tooltip">The Bank of Orrick</span>
            </div>

            <div class="logo-badge" role="listitem" aria-label="Hyphen Finance">
              <img src="/logos/hyphenfi_logo.jfif" alt="Hyphen Finance" class="h-12 w-auto object-contain" />
              <span class="logo-tooltip">Hyphen Finance</span>
            </div>

            <div class="logo-badge" role="listitem" aria-label="KAR Global">
              <img src="/logos/kar_auction_services_inc_logo.jfif" alt="KAR Global" class="h-12 w-auto object-contain" />
              <span class="logo-tooltip">KAR Global</span>
            </div>

          </div>
        </div>
      </div>

      <!-- Card 3: Contact -->
      <div class="glass rounded-3xl p-6 text-left" role="region" aria-label="Contact information">
        <h2 class="h2-divider mb-4 text-[10px] font-semibold uppercase tracking-widest text-slate-400">Contact</h2>
        <nav class="grid gap-2 text-sm">
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="mailto:henrycarmenateg@gmail.com"
            aria-label="Send email to Henry Carmenate"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            henrycarmenateg@gmail.com
          </a>
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="tel:+1-786-316-5465"
            aria-label="Call +1 (786) 316-5465"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (786) 316-5465
          </a>
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="https://www.linkedin.com/in/henry-carmenate/"
            rel="noopener noreferrer"
            target="_blank"
            aria-label="Visit LinkedIn profile"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a
            class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3.5 py-2.5 transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="https://github.com/hhcarmenate"
            rel="noopener noreferrer"
            target="_blank"
            aria-label="Visit GitHub profile"
          >
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.929.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </nav>
      </div>

    </div>
  </div>

  <!-- ── Bottom stats bar ── -->
  <div class="border-t border-white/[0.06]">
    <div class="reveal mx-auto flex max-w-6xl items-center justify-between px-6 py-5" style="--reveal-delay: 500ms">
      <div class="flex items-center gap-8 lg:gap-14" role="doc-credits">
        <div>
          <p class="text-2xl font-bold text-cyan-300" aria-label="15 years of experience">15+</p>
          <p class="text-xs text-slate-400">Years Experience</p>
        </div>
        <div class="h-8 w-px bg-white/10" aria-hidden="true"></div>
        <div>
          <p class="text-2xl font-bold text-cyan-300" aria-label="40 or more modules migrated">40+</p>
          <p class="text-xs text-slate-400">Modules Migrated</p>
        </div>
        <div class="h-8 w-px bg-white/10" aria-hidden="true"></div>
        <div>
          <p class="text-2xl font-bold text-cyan-300" aria-label="35 percent load time reduced">35%</p>
          <p class="text-xs text-slate-400">Load Time Reduced</p>
        </div>
      </div>
      <div class="scroll-hint flex flex-col items-center gap-1.5 opacity-40 outline-none" aria-hidden="true" role="img">
        <p class="text-[10px] uppercase tracking-widest text-slate-400">Scroll</p>
        <svg class="h-4 w-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </div>

</section>

<style>
  /* Excluded from global h1 gradient; only .hero-gradient-text uses background-clip. */
  .hero-headline {
    line-height: 1.12;
    overflow: visible;
    padding-bottom: 0.08em;
    color: #ffffff;
  }

  /* ── Gradient headline ── */
  .hero-gradient-text {
    background: linear-gradient(120deg, #fff 20%, var(--c-secondary) 60%, var(--c-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Availability ping ── */
  .ping-dot {
    animation: ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping {
    75%, 100% { transform: scale(2.2); opacity: 0; }
  }

  /* ── CTA glow pulse ── */
  .glow-pulse {
    animation: glowPulse 2.2s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { box-shadow: 0 0 18px rgba(34, 211, 238, 0.35); }
    50%       { box-shadow: 0 0 38px rgba(34, 211, 238, 0.60); }
  }

  /* ── Scroll hint bounce ── */
  .scroll-hint {
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  /* ── Reveal animation ── */
  .reveal {
    animation: revealFade 700ms ease forwards;
    opacity: 0;
    transform: translateY(20px);
    filter: blur(6px);
  }

  .reveal.reveal--visible {
    animation: revealShow 700ms ease forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  @keyframes revealFade {
    to { opacity: 0; transform: translateY(20px); filter: blur(6px); }
  }

  @keyframes revealShow {
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .glow-pulse,
    .ping-dot,
    .scroll-hint,
    .h2-divider {
      animation: none;
    }
    .reveal {
      opacity: 1;
      transform: none;
      filter: none;
      animation: none;
    }
  }

  /* ── Company logo badges with tooltip ── */
  .logo-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    filter: grayscale(1);
    opacity: 0.8;
    transition: filter 0.3s ease, opacity 0.3s ease, background 0.3s ease;
    cursor: default;
  }

  .logo-badge:hover {
    filter: grayscale(0);
    opacity: 1;
    background: rgba(255, 255, 255, 0.09);
  }

  .logo-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    white-space: nowrap;
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #cbd5e1;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 4px 10px;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    backdrop-filter: blur(8px);
    z-index: 10;
  }

  .logo-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: rgba(255, 255, 255, 0.1);
  }

  .logo-badge:hover .logo-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Print styles ── */
  @media print {
    .scroll-hint,
    .ping-dot {
      display: none;
    }
  }
</style>
