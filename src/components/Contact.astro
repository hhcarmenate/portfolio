---
import LucideIcon from './LucideIcon.astro';
import { Mail, Phone, Link2, Send } from 'lucide';

const web3formsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';

const channels = [
  {
    label: 'Email',
    href: 'mailto:henrycarmenateg@gmail.com',
    value: 'henrycarmenateg@gmail.com',
    icon: Mail,
    external: false,
  },
  {
    label: 'Phone',
    href: 'tel:+1-786-316-5465',
    value: '(786) 316-5465',
    icon: Phone,
    external: false,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/henry-carmenate/',
    value: 'henry-carmenate',
    icon: Link2,
    external: true,
  },
];
---

<section id="contact" class="contact-section mx-auto max-w-7xl px-6 section-spacing reveal">
  <header class="contact-header max-w-2xl">
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-teal-400/85 md:text-xs">Contact</p>
    <h2 class="h2-divider mt-3 text-3xl font-bold tracking-tight text-white md:text-4xl">
      Let’s build something that holds up in production
    </h2>
    <p class="mt-3 text-base leading-relaxed text-slate-400">
      Roles, contracts, or technical collaboration — I read messages promptly and keep follow-ups concrete.
    </p>
  </header>

  <div class="contact-shell reveal mt-10 glass rounded-3xl border border-white/[0.08] p-6 md:p-10 lg:p-12">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-start lg:gap-12">
      <div class="lg:col-span-5">
        <p class="contact-aside-label">Direct lines</p>
        <ul class="mt-5 space-y-3">
          {
            channels.map((c) => (
              <li>
                <a
                  href={c.href}
                  class="contact-channel group flex items-start gap-4 rounded-2xl border border-white/[0.07] bg-white/[0.02] p-4 transition-colors duration-300 hover:border-white/14 hover:bg-white/[0.05]"
                  target={c.external ? '_blank' : undefined}
                  rel={c.external ? 'noopener noreferrer' : undefined}
                  aria-label={c.external ? `${c.label} (opens in a new tab)` : c.label}
                >
                  <span class="contact-channel-icon inline-flex rounded-xl border border-white/10 bg-white/[0.04] p-2.5 text-teal-300/95">
                    <LucideIcon icon={c.icon} size={20} />
                  </span>
                  <span class="min-w-0">
                    <span class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">{c.label}</span>
                    <span class="mt-1 block break-words text-sm font-medium text-slate-100 transition-colors group-hover:text-white md:text-[15px]">
                      {c.value}
                    </span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>

        <p class="mt-8 text-sm leading-relaxed text-slate-500">
          Prefer a quick thread first — share stack, timeline, and what “done” looks like; I’ll respond with clarity on fit
          and next steps.
        </p>
      </div>

      <div class="lg:col-span-7">
        <div class="contact-form-wrap rounded-3xl border border-white/[0.08] bg-slate-950/35 p-6 md:p-8">
          <div class="flex items-center gap-3">
            <span class="inline-flex rounded-xl border border-teal-400/25 bg-teal-500/10 p-2 text-teal-200">
              <LucideIcon icon={Send} size={20} />
            </span>
            <div>
              <p class="text-base font-semibold text-white">Send a message</p>
              <p class="mt-0.5 text-sm text-slate-500">I’ll follow up by email. No spam — product talk only.</p>
            </div>
          </div>

          <form class="mt-6" id="contact-form">
            <div class="grid gap-4">
              <div>
                <label for="email-input" class="contact-label mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">
                  Email
                </label>
                <input
                  id="email-input"
                  class="contact-input w-full rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3.5 text-sm text-slate-100 placeholder:text-slate-500 transition-colors duration-300 focus:border-teal-400/40 focus:bg-white/[0.07] focus:outline-none focus:ring-2 focus:ring-teal-400/20"
                  placeholder="you@company.com"
                  type="email"
                  name="email"
                  autocomplete="email"
                  required
                />
              </div>
              <div>
                <label for="message-input" class="contact-label mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">
                  Message
                </label>
                <textarea
                  id="message-input"
                  class="contact-input min-h-[132px] w-full rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3.5 text-sm text-slate-100 placeholder:text-slate-500 transition-colors duration-300 focus:border-teal-400/40 focus:bg-white/[0.07] focus:outline-none focus:ring-2 focus:ring-teal-400/20"
                  placeholder="Role, stack, timeline, and what you need delivered."
                  rows="4"
                  name="message"
                  required
                />
              </div>
              <p
                id="contact-form-status"
                class="min-h-5 text-sm leading-snug text-slate-400 empty:hidden"
                role="status"
                aria-live="polite"
              />
              <button
                id="contact-form-submit"
                class="contact-submit inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-2xl px-6 py-3.5 text-sm font-semibold text-white transition-[transform,box-shadow] duration-300 hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:opacity-60 disabled:hover:translate-y-0 sm:w-auto"
                type="submit"
              >
                <LucideIcon icon={Send} size={18} class="opacity-95" />
                <span data-submit-label>Send message</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-shell {
    box-shadow: 0 28px 64px -44px rgba(0, 0, 0, 0.85);
  }

  .contact-aside-label {
    margin: 0;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(94, 234, 212, 0.78);
  }

  .contact-submit {
    background: linear-gradient(135deg, var(--accent-2), var(--c-primary));
    box-shadow: 0 10px 32px -14px rgba(45, 212, 191, 0.28);
  }

  .contact-submit:hover {
    box-shadow: 0 14px 40px -12px rgba(45, 212, 191, 0.32);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-submit:hover {
      transform: none;
    }
  }
</style>

<script define:vars={{ web3formsAccessKey }}>
  (function () {
    const form = document.getElementById('contact-form');
    const statusEl = document.getElementById('contact-form-status');
    const submitBtn = document.getElementById('contact-form-submit');
    const submitLabel = submitBtn?.querySelector('[data-submit-label]');

    if (!form || !statusEl) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusEl.textContent = '';
      statusEl.classList.remove('text-teal-300/95', 'text-red-300/90');

      if (!web3formsAccessKey) {
        statusEl.classList.add('text-red-300/90');
        statusEl.textContent =
          'Contact form is not configured. Add PUBLIC_WEB3FORMS_ACCESS_KEY to your environment and rebuild.';
        return;
      }

      const fd = new FormData(form);
      const email = String(fd.get('email') ?? '').trim();
      const message = String(fd.get('message') ?? '').trim();

      submitBtn?.setAttribute('disabled', 'true');
      if (submitLabel) submitLabel.textContent = 'Sending…';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            access_key: web3formsAccessKey,
            subject: 'Portfolio contact',
            from_name: email.includes('@') ? email.split('@')[0] : 'Portfolio visitor',
            email,
            message,
          }),
        });
        const data = await res.json();

        if (data.success) {
          statusEl.classList.add('text-teal-300/95');
          statusEl.textContent = 'Thanks — your message was sent. I’ll get back to you soon.';
          form.reset();
        } else {
          statusEl.classList.add('text-red-300/90');
          statusEl.textContent =
            typeof data.message === 'string' ? data.message : 'Something went wrong. Try email or LinkedIn instead.';
        }
      } catch {
        statusEl.classList.add('text-red-300/90');
        statusEl.textContent = 'Network error. Please try again or use the email link above.';
      } finally {
        submitBtn?.removeAttribute('disabled');
        if (submitLabel) submitLabel.textContent = 'Send message';
      }
    });
  })();
</script>
