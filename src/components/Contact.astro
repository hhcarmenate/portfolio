---
// Contact section
---

<section id="contact" class="mx-auto max-w-7xl px-6 section-spacing reveal">
  <div class="rounded-3xl bg-white/5 p-6 ring-1 ring-white/10 md:p-10 reveal">
    <div class="grid gap-8 md:grid-cols-12 md:items-center">
      <div class="md:col-span-7">
        <h2 class="h2-divider text-3xl font-semibold tracking-tight">Let's build something together.</h2>
        <p class="mt-2 text-sm text-slate-300">Want to talk about a role, a contract, or collaboration? I reply quickly.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            class="ring-brand inline-flex items-center justify-center rounded-2xl bg-white/5 px-5 py-3 text-sm font-semibold transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="mailto:henrycarmenateg@gmail.com"
          >
            henrycarmenateg@gmail.com
          </a>
          <a
            class="ring-brand inline-flex items-center justify-center rounded-2xl bg-white/5 px-5 py-3 text-sm font-semibold transition-colors duration-300 ring-1 ring-white/10 hover:bg-white/10"
            href="tel:+1-786-316-5465"
            aria-label="Call +1 (786) 316-5465"
          >
            (786) 316-5465
          </a>
        </div>
      </div>

      <div class="md:col-span-5">
        <form class="rounded-3xl bg-slate-950/40 p-5 ring-1 ring-white/10 reveal" id="contact-form">
          <p class="text-sm font-semibold">Quick message</p>
          <div class="mt-4 grid gap-3">
            <div>
              <label for="email-input" class="block text-xs text-slate-400 mb-1.5">Email</label>
              <input
                id="email-input"
                class="ring-brand w-full rounded-2xl bg-white/5 px-4 py-3 text-sm text-slate-100 transition-colors duration-300 ring-1 ring-white/10 placeholder:text-slate-500 focus:bg-white/10 focus:ring-cyan-400/50"
                placeholder="your@email.com"
                type="email"
                name="email"
                autocomplete="email"
                required
              />
            </div>
            <div>
              <label for="message-input" class="block text-xs text-slate-400 mb-1.5">Message</label>
              <textarea
                id="message-input"
                class="ring-brand min-h-[110px] w-full rounded-2xl bg-white/5 px-4 py-3 text-sm text-slate-100 transition-colors duration-300 ring-1 ring-white/10 placeholder:text-slate-500 focus:bg-white/10 focus:ring-cyan-400/50"
                placeholder="Tell me about your project..."
                rows="4"
                name="message"
              ></textarea>
            </div>
            <button
              class="ring-brand rounded-2xl bg-white/5 px-4 py-3 text-sm font-semibold transition-all duration-300 ring-1 ring-white/10 hover:bg-white/10 hover:scale-105"
              type="submit"
            >
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const contactForm = document.getElementById('contact-form');

  if (contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      // Form submission can be wired to a form provider (Formspree, Basin, etc.)
      // For now, prevent default submission
    });
  }
</script>
