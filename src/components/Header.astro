---
// No props needed for this component
---

<header
  class="sticky top-0 z-50 border-b border-white/0 bg-white/0 transition-all duration-300"
  id="header"
>
  <div class="mx-auto max-w-7xl px-6 py-4">
    <nav
      aria-label="Main navigation"
      class="flex items-center justify-between"
    >
      <!-- Logo / Brand -->
      <a
        href="#top"
        class="inline-flex items-center gap-2 font-semibold tracking-tight transition-colors duration-300 hover:text-teal-300"
      >
        <span
          class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-white/5 ring-1 ring-white/10"
        >
          <span class="text-sm" style="color: var(--c-primary)">HC</span>
        </span>
        <span class="text-zinc-100 tracking-[0.12em]">HENRY CARMENATE</span>
      </a>

      <!-- Hamburger Menu (Mobile) -->
      <input
        type="checkbox"
        id="nav-toggle"
        class="hidden"
        aria-label="Toggle navigation menu"
      />
      <label
        for="nav-toggle"
        class="flex cursor-pointer flex-col gap-1.5 md:hidden"
      >
        <span
          class="block h-0.5 w-6 rounded-full bg-white/70 transition-all duration-300"
        ></span>
        <span
          class="block h-0.5 w-6 rounded-full bg-white/70 transition-all duration-300"
        ></span>
        <span
          class="block h-0.5 w-6 rounded-full bg-white/70 transition-all duration-300"
        ></span>
      </label>

      <!-- Navigation Links -->
      <div
        class="absolute left-0 right-0 top-full hidden flex-col gap-2 border-b border-white/10 bg-white/5 p-5 backdrop-blur-md md:relative md:top-auto md:flex md:flex-row md:border-none md:bg-transparent md:p-0 md:backdrop-blur-none"
        id="nav-menu"
      >
        <a
          href="#projects"
          class="nav-link rounded-xl px-3 py-2 text-sm text-slate-200/90 transition-all duration-300 hover:bg-white/5 hover:underline"
          data-section="projects"
        >
          Projects
        </a>
        <a
          href="#experience"
          class="nav-link rounded-xl px-3 py-2 text-sm text-slate-200/90 transition-all duration-300 hover:bg-white/5 hover:underline"
          data-section="experience"
        >
          Experience
        </a>
        <a
          href="#skills"
          class="nav-link rounded-xl px-3 py-2 text-sm text-slate-200/90 transition-all duration-300 hover:bg-white/5 hover:underline"
          data-section="skills"
        >
          Skills
        </a>
        <a
          href="#contact"
          class="nav-link rounded-xl px-3 py-2 text-sm text-slate-200/90 transition-all duration-300 hover:bg-white/5 hover:underline"
          data-section="contact"
        >
          Contact
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Mobile hamburger toggle
  const navToggle = document.getElementById('nav-toggle');
  const navMenu = document.getElementById('nav-menu');

  navToggle?.addEventListener('change', () => {
    if (navToggle instanceof HTMLInputElement && navToggle.checked) {
      navMenu?.classList.remove('hidden');
    } else {
      navMenu?.classList.add('hidden');
    }
  });

  // Close menu when a link is clicked
  document.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (navToggle instanceof HTMLInputElement) navToggle.checked = false;
      navMenu?.classList.add('hidden');
    });
  });

  // Sticky header scroll effect
  const header = document.getElementById('header');
  let lastScrollY = 0;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    if (scrollY > 10) {
      header?.classList.add('border-white/10', 'bg-white/5', 'backdrop-blur');
      header?.classList.remove('bg-white/0', 'border-white/0');
    } else {
      header?.classList.remove('border-white/10', 'bg-white/5', 'backdrop-blur');
      header?.classList.add('bg-white/0', 'border-white/0');
    }

    lastScrollY = scrollY;
  });

  // Active nav: last section whose top has crossed the "activation line" below the sticky header.
  // IntersectionObserver + aggressive rootMargin only matched Skills reliably; scroll position is clearer.
  const navLinks = document.querySelectorAll('.nav-link');
  const sectionIds = ['projects', 'experience', 'skills', 'contact'];

  const activeClasses = [
    'text-teal-300',
    'font-semibold',
    'ring-1',
    'ring-teal-500/25',
    'bg-teal-500/10',
  ];
  const idleClasses = ['text-slate-200/90'];

  function clearNavActive() {
    navLinks.forEach((link) => {
      link.classList.remove(...activeClasses);
      link.classList.add(...idleClasses);
    });
  }

  function updateActiveNav() {
    const headerEl = document.getElementById('header');
    const headerOffset = (headerEl?.getBoundingClientRect().height ?? 72) + 8;
    const y = window.scrollY + headerOffset;

    const projectsEl = document.getElementById('projects');
    if (projectsEl) {
      const projectsTop = projectsEl.getBoundingClientRect().top + window.scrollY;
      if (y < projectsTop) {
        clearNavActive();
        return;
      }
    }

    let activeId = 'projects';
    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (!el) continue;
      const top = el.getBoundingClientRect().top + window.scrollY;
      if (y >= top) activeId = id;
    }
    clearNavActive();
    navLinks.forEach((link) => {
      if (link.getAttribute('data-section') === activeId) {
        link.classList.remove(...idleClasses);
        link.classList.add(...activeClasses);
      }
    });
  }

  let ticking = false;
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          updateActiveNav();
          ticking = false;
        });
      }
    },
    { passive: true }
  );

  updateActiveNav();
</script>

<style>
  #nav-toggle:checked ~ #nav-menu {
    display: flex;
  }

  #nav-toggle:checked ~ label span:nth-child(1) {
    transform: rotate(45deg) translateY(12px);
  }

  #nav-toggle:checked ~ label span:nth-child(2) {
    opacity: 0;
  }

  #nav-toggle:checked ~ label span:nth-child(3) {
    transform: rotate(-45deg) translateY(-12px);
  }
</style>
