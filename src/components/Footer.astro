---
import LucideIcon from './LucideIcon.astro';
import { ArrowUp, Mail, BriefcaseBusiness, Code2 } from 'lucide';

const exploreLinks = [
  { href: '#projects', label: 'Projects' },
  { href: '#philosophy', label: 'Philosophy' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#contact', label: 'Contact' },
] as const;

const connectLinks = [
  {
    href: 'mailto:henrycarmenateg@gmail.com',
    label: 'Email',
    detail: 'henrycarmenateg@gmail.com',
    icon: Mail,
    external: false,
  },
  {
    href: 'https://www.linkedin.com/in/henry-carmenate/',
    label: 'LinkedIn',
    detail: 'Profile & experience',
    icon: BriefcaseBusiness,
    external: true,
  },
  {
    href: 'https://github.com/hhcarmenate',
    label: 'GitHub',
    detail: 'Code & experiments',
    icon: Code2,
    external: true,
  },
] as const;
---

<footer class="footer-root relative border-t border-white/[0.08]">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 mx-auto h-px max-w-7xl bg-gradient-to-r from-transparent via-cyan-400/30 to-transparent px-6 opacity-90"
    aria-hidden="true"
  />

  <div class="mx-auto max-w-7xl px-6 pb-10 pt-12 md:pb-12 md:pt-14">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-400/85">Henry Carmenate</p>
        <p class="mt-3 max-w-md text-sm font-semibold leading-snug text-white md:text-base">
          Senior Full-Stack Engineer — production systems with Laravel, Vue, and AWS.
        </p>
        <p class="mt-3 max-w-md text-sm leading-relaxed text-slate-500">
          Based in Miami, FL. Open to remote roles and thoughtful contract work.
        </p>

        <a
          href="#top"
          class="footer-back-top group mt-8 inline-flex min-h-[44px] items-center gap-2 rounded-2xl border border-white/12 bg-white/[0.03] px-5 py-2.5 text-sm font-medium text-slate-200 transition-[border-color,background,color,transform] duration-300 hover:border-cyan-400/25 hover:bg-white/[0.06] hover:text-white md:mt-10"
        >
          <LucideIcon
            icon={ArrowUp}
            size={18}
            class="text-cyan-300/90 transition-transform duration-300 group-hover:-translate-y-0.5 motion-reduce:transition-none motion-reduce:group-hover:translate-y-0"
          />
          Back to top
        </a>
      </div>

      <nav class="lg:col-span-3" aria-label="Footer — page sections">
        <p class="footer-col-label">Explore</p>
        <ul class="mt-4 space-y-1">
          {
            exploreLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="footer-text-link inline-flex rounded-lg py-1.5 text-sm text-slate-400 transition-colors duration-300 hover:text-cyan-200/95"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="lg:col-span-4">
        <p class="footer-col-label">Connect</p>
        <ul class="mt-4 space-y-3">
          {
            connectLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="footer-connect-card group flex items-start gap-3 rounded-2xl border border-white/[0.07] bg-white/[0.02] p-3.5 transition-[border-color,background] duration-300 hover:border-white/14 hover:bg-white/[0.05]"
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener noreferrer' : undefined}
                  aria-label={item.external ? `${item.label} (opens in a new tab)` : item.label}
                >
                  <span class="footer-connect-icon inline-flex rounded-xl border border-white/10 bg-white/[0.04] p-2 text-cyan-300/90">
                    <LucideIcon icon={item.icon} size={18} />
                  </span>
                  <span class="min-w-0">
                    <span class="block text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">{item.label}</span>
                    <span class="mt-0.5 block text-sm font-medium text-slate-200 transition-colors group-hover:text-white">
                      {item.detail}
                    </span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="footer-bottom mt-12 flex flex-col gap-3 border-t border-white/[0.06] pt-8 md:flex-row md:items-center md:justify-between">
      <p class="text-xs leading-relaxed text-slate-500">
        © <span id="year"></span> Henry Carmenate. All rights reserved.
      </p>
      <p class="text-xs text-slate-500">
        Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-400 underline decoration-white/15 underline-offset-2 transition-colors hover:text-cyan-300/90 hover:decoration-cyan-500/35"
        >
          Astro
        </a>
        — static, fast, and maintainable.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-col-label {
    margin: 0;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.88);
  }
</style>
