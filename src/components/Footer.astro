---
// Footer component
---

<footer class="relative border-t border-white/10">
  <div class="mx-auto max-w-7xl px-6 py-8">
    <div class="grid gap-6 md:grid-cols-3 md:items-center">
      <!-- Copyright -->
      <p class="text-xs text-slate-400">
        © <span id="year"></span> Henry Carmenate. Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-cyan-300 hover:text-cyan-400 transition-colors duration-300">Astro</a>.
      </p>

      <!-- Social Links -->
      <div class="flex justify-center items-center gap-3">
        <a
          href="https://www.linkedin.com/in/henry-carmenate/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="inline-flex items-center justify-center h-9 w-9 rounded-full bg-white/5 ring-1 ring-white/10 hover:bg-white/10 transition-all duration-300 text-slate-300 hover:text-cyan-300"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.946v5.441h-3.554s.05-8.816 0-9.753h3.554v1.383c.43-.664 1.199-1.61 2.925-1.61 2.135 0 3.73 1.39 3.73 4.393v5.587zM5.337 8.855c-1.144 0-1.915-.762-1.915-1.715 0-.955.77-1.715 1.959-1.715 1.188 0 1.915.76 1.932 1.715 0 .953-.744 1.715-1.976 1.715zm1.946 11.597H3.392V9.201h3.891v11.251zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" />
          </svg>
        </a>
        <a
          href="https://github.com/hhcarmenate"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="inline-flex items-center justify-center h-9 w-9 rounded-full bg-white/5 ring-1 ring-white/10 hover:bg-white/10 transition-all duration-300 text-slate-300 hover:text-cyan-300"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
        </a>
      </div>

      <!-- Back to Top -->
      <div class="flex justify-end">
        <a
          href="#top"
          class="inline-flex items-center gap-2 rounded-2xl bg-white/5 px-4 py-2 text-xs font-semibold text-slate-300 transition-all duration-300 ring-1 ring-white/10 hover:bg-white/10 hover:text-cyan-300 hover:scale-105"
        >
          Back to top ↑
        </a>
      </div>
    </div>
  </div>
</footer>
